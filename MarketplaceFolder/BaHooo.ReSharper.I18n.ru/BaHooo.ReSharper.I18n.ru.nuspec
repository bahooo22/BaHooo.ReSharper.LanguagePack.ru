<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <!-- IDENTIFICATION -->
    <id>BaHooo.ReSharper.I18n.ru</id>
    <version>2025.3.3.11</version>
    <title>Russian Localization for .NET Tools (BaHooo)</title>

    <!-- AUTHORS -->
    <authors>Ivan "BaHooo" Zelenkevich</authors>
    <owners>Ivan "BaHooo" Zelenkevich</owners>

    <!-- LINKS -->
    <projectUrl>https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/tree/main/MarketplaceFolder/BaHooo.ReSharper.I18n.ru</projectUrl>
    <repository type="git" url="https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/tree/main/MarketplaceFolder/BaHooo.ReSharper.I18n.ru" />
	<licenseUrl>https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/blob/main/LICENSE</licenseUrl>
    <icon>icon.png</icon>

    <!-- SHORT SUMMARY -->
    <summary>
      Russian UI translation for .NET IDE extensions / Русская локализация интерфейса
    </summary>

    <!-- FULL DESCRIPTION -->
<description><![CDATA[
<p><strong>Russian Language Pack for ReSharper</strong></p>
<p>This package provides a Russian language interface for ReSharper, a popular extension for .NET developers.<br/>
Translation authored by Ivan "BaHooo" Zelenkevich.<br/>
Your feedback is very much appreciated — you can submit issues on 
<a href="https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/issues">GitHub</a> or contact via <a href="https://t.me/compohelp_vitebsk">Telegram</a>.</p>
<p />
<p><em>Key features:</em></p>
<ul>
  <li>Complete translation of ReSharper UI strings</li>
  <li>Consistent terminology based on a unified glossary</li>
  <li>Support for ReSharper 2025.3 and later</li>
  <li>Feedback channels via <a href="https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/issues">GitHub Issues</a> and <a href="https://t.me/compohelp_vitebsk">Telegram</a></li>
</ul>
<p />
<p><strong>📦 Source Code &amp; License</strong></p>
<ul>
  <li><strong>Source Code:</strong> Available on <a href="https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/tree/main/raw-resx-done_ru-RU">GitHub</a>.</li>
  <li><strong>License:</strong> This translation is licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a>.
    <br/>Commercial use requires a separate agreement with the author. See the included <code>LICENSE</code> file for full terms.</li>
</ul>
<p />
<p><em>Examples of translated UI elements:</em></p>
<ul>
  <li><code>PleaseHelpUsImprove_Text</code> → “Помогите нам стать лучше”</li>
  <li><code>ConvertThemedIconsActionText</code> → “Преобразовать тематические значки…”</li>
  <li><code>DisableOtherInstance_Text</code> → “Отключить другой экземпляр”</li>
  <li><code>ProvideFeedback_Text</code> → “Оставить отзыв”</li>
  <li><code>CopyFullPathActionText</code> → “Копировать полный путь”</li>
</ul>
<p />
<p><em>Project milestones:</em><br/>
2024.11.13 — Anna "Pixel" Zelenkevich Birthday<br/>
2025.11.27 — Project started<br/>
2025.12.1 — Date of first build</p>

<hr/>
<p />
<p><strong>Русский языковой пакет для ReSharper</strong></p>
<p>Этот пакет переводит интерфейс ReSharper на русский язык.<br/>
Перевод выполнен Иваном "BaHooo" Зеленкевичем.<br/>
Обратная связь приветствуется — используйте 
<a href="https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/issues">GitHub Issues</a> или <a href="https://t.me/compohelp_vitebsk">Telegram</a>.</p>
<p />
<p><em>Основные возможности:</em></p>
<ul>
  <li>Полный перевод строк интерфейса ReSharper</li>
  <li>Единая терминология на основе глоссария</li>
  <li>Поддержка ReSharper 2025.3 и новее</li>
  <li>Каналы обратной связи через <a href="https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/issues">GitHub Issues</a> и <a href="https://t.me/compohelp_vitebsk">Telegram</a></li>
</ul>
<p />
<p><strong>📦 Исходный код и лицензия</strong></p>
<ul>
  <li><strong>Исходный код:</strong> Доступен на <a href="https://github.com/bahooo22/BaHooo.ReSharper.LanguagePack.ru/tree/main/raw-resx-done_ru-RU">GitHub</a>.</li>
  <li><strong>Лицензия:</strong> Данный перевод распространяется под лицензией <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a>.
    <br/>Коммерческое использование возможно только по отдельному соглашению с автором. Полные условия — в файле <code>LICENSE.md</code>.</li>
</ul>
<p />
<p><em>Примеры перевода элементов интерфейса:</em></p>
<ul>
  <li><code>PleaseHelpUsImprove_Text</code> → «Помогите нам стать лучше»</li>
  <li><code>ConvertThemedIconsActionText</code> → «Преобразовать тематические значки…»</li>
  <li><code>DisableOtherInstance_Text</code> → «Отключить другой экземпляр»</li>
  <li><code>ProvideFeedback_Text</code> → «Оставить отзыв»</li>
  <li><code>CopyFullPathActionText</code> → «Копировать полный путь»</li>
</ul>
<p />
<p><em>Вехи проекта:</em><br/>
2024.11.27 — Родилась Аня "Pixel" Зеленкевич<br/>
2025.11.27 — Проект начат<br/>
2025.12.1 — Дата первой сборки</p>
]]></description>

    <!-- RELEASE NOTES -->
    <releaseNotes><![CDATA[
English:
- Initial release of the Russian Language Pack for ReSharper
- Full translation of UI resources
- Added feedback channels (GitHub, Telegram)

Русский:
- Первый релиз русской локализации ReSharper
- Полный перевод строк интерфейса
- Добавлены каналы обратной связи (GitHub, Telegram)
]]></releaseNotes>

    <!-- TAGS -->
    <tags>resharper localization russian language-pack i18n</tags>

    <!-- DEPENDENCIES -->
    <dependencies>
      <!-- Wave version from official ReSharper 2025.3 builds -->
      <dependency id="Wave" version="[253.0.0]" />
    </dependencies>

    <!-- LANGUAGE -->
    <language>ru-RU</language>

    <!-- README -->
    <readme>README.md</readme>

    <!-- REQUIRED NUGET METADATA -->
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <developmentDependency>false</developmentDependency>
    <serviceable>false</serviceable>

    <!-- COPYRIGHT -->
    <copyright>
      © 2025 Ivan "BaHooo" Zelenkevich. This is a community translation.
    </copyright>
  </metadata>

  <files>
    <!-- ICON -->
    <file src="icon.png" target="icon.png" />

    <!-- README -->
    <file src="README.md" target="README.md" />

    <!-- LICENSE FILE -->
    <file src="..\..\LICENSE" target="LICENSE" />

    <!-- ALL .resources FILES FOR LOCALIZATION -->
    <file src="DotFiles\Extensions\BaHooo.ReSharper.I18n.ru\i18n\*.resources"
          target="DotFiles/Extensions/BaHooo.ReSharper.I18n.ru/i18n" />
  </files>
</package>